l,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\&quot;broadcast_whitelist\&quot;:[460713512,1211900379,1211669732,1211779741,1211662629,1211730895,1211846108,1211619562,1211626238,1211798668,1212039568,1722511188,1723730393,1722701501,1722730783,1722814549,1722003791],\&quot;bScheduleEnabled\&quot;:false,\&quot;scheduleEntries\&quot;:[],\&quot;valve_access_log\&quot;:[{\&quot;strSteamID\&quot;:\&quot;76561199499120513\&quot;,\&quot;rtUpdated\&quot;:1777482082}],\&quot;broadcast_language\&quot;:[0],\&quot;broadcast_priority\&quot;:[\&quot;primary\&quot;,\&quot;default_featured\&quot;,\&quot;default_featured\&quot;,\&quot;default_featured\&quot;,\&quot;default_featured\&quot;,\&quot;default_featured\&quot;,\&quot;featured\&quot;,\&quot;featured\&quot;,\&quot;featured\&quot;,\&quot;featured\&quot;,\&quot;featured\&quot;,\&quot;featured\&quot;,\&quot;\&quot;,\&quot;featured\&quot;,\&quot;featured\&quot;,\&quot;featured\&quot;,\&quot;primary\&quot;],\&quot;clone_from_event_gid\&quot;:\&quot;563646078927241633\&quot;,\&quot;clone_from_sale_enabled\&quot;:true,\&quot;sale_presenters\&quot;:[{\&quot;unique_id\&quot;:67722,\&quot;localized_presenter_name\&quot;:[\&quot;Paradox Interactive\&quot;,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null],\&quot;url\&quot;:\&quot;https:\\\/\\\/www.paradoxinteractive.com\\\/our-games\\\/discover\&quot;}],\&quot;broadcast_force_banner\&quot;:true,\&quot;sale_associated_advertising_appid\&quot;:1644360,\&quot;broadcast_gradient_inner_color\&quot;:\&quot;rgba(255, 255, 255, 0.1)\&quot;,\&quot;broadcast_gradient_outer_color\&quot;:\&quot;rgba(255, 255, 255, 0.09)\&quot;,\&quot;sale_vanity_id\&quot;:\&quot;pdxpubsale26\&quot;,\&quot;sale_vanity_id_valve_approved_for_sale_subpath\&quot;:true}&quot;,&quot;announcement_body&quot;:{&quot;gid&quot;:&quot;532127297744929950&quot;,&quot;clanid&quot;:&quot;6859167&quot;,&quot;posterid&quot;:&quot;76561199002299579&quot;,&quot;headline&quot;:&quot;Paradox Publisher Sale 2026&quot;,&quot;posttime&quot;:1777568452,&quot;updatetime&quot;:1777568507,&quot;body&quot;:&quot;[p]Command your calendar\u2014this is not a drill, it\u2019s a full-scale campaign. The Paradox Interactive Publisher Sale on Steam has begun, and the only winning move is to expand aggressively. Whether you\u2019re a grand strategist, an economy optimizer, or a chaos-enjoying ruler, this is your moment to seize territory in your game library.[\/p][p][b]Ride the wave of history[\/b]\nCelebrate the launch of [i]Victoria 3: The Great Wave[\/i] with a free-to-play on the base game. Industrialize, reform, and occasionally panic-manage your population as you surf the tides of progress\u2014just try not to let your economy crash harder than your ambitions.[\/p][p][b]Min-max your deals[\/b]\nWe\u2019re talking all-time high discounts on [i]Roads to Power[\/i], [i]Stellaris Starter Edition[\/i], and [i]Dawn of Wonder[\/i]. That\u2019s right\u2014peak efficiency pricing. If your strategy is \u201cbuy low, conquer high,\u201d you\u2019ve just found your optimal build order.[\/p][p][b]Unlock new fronts[\/b]\nFor the first time ever, step into the shadows with discounts on [i]Bloodlines 2 Premium Edition[\/i] and [i]No Compromise, No Surrender[\/i]. Whether you're pulling strings in the dark or refusing to back down, these are first-time opportunities you won\u2019t want to let slip through your diplomatic grasp.[\/p][p]Every decision matters\u2014but this one\u2019s easy. Don\u2019t let analysis paralysis stall your campaign. Wishlist, cart, conquer.[\/p]&quot;,&quot;commentcount&quot;:0,&quot;tags&quot;:[&quot;curator&quot;,&quot;curator_public&quot;],&quot;language&quot;:0,&quot;hidden&quot;:0,&quot;forum_topic_id&quot;:&quot;837249163025594666&quot;,&quot;event_gid&quot;:&quot;532127297744929949&quot;,&quot;vote